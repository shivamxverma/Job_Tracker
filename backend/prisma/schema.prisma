datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Job {
  id         String    @id @default(cuid())
  source     String    // e.g. "wellfound", "yc", "linkedin"
  externalId String    @map("external_id")
  title      String
  company    String
  location   String
  salary     String?
  applyUrl   String?   @map("apply_url")
  description String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")

  // Tracking fields
  status     String?
  platform   String?
  notes      String?
  appliedAt  DateTime? @map("applied_at")

  // Relations for Auto Apply System
  applications Application[]
  resumes      ResumeVersion[]

  @@unique([source, externalId])
  @@index([source])
  @@index([company])
  @@index([status])
}

model Application {
  id               String         @id @default(cuid())
  jobId            String         @map("job_id")
  userId           String         @map("user_id") @default("default-user")
  status           String         // QUEUED, GENERATING_RESUME, READY_TO_APPLY, APPLYING, APPLIED, FAILED
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  appliedAt        DateTime?      @map("applied_at")
  errorMessage     String?        @map("error_message")
  resumeVersionId  String?        @map("resume_version_id")

  job              Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion    ResumeVersion? @relation("AppToResume", fields: [resumeVersionId], references: [id])
  resumeVersions   ResumeVersion[] @relation("JobAppResumes")

  @@index([jobId])
  @@index([userId])
  @@index([status])
}

model ResumeVersion {
  id            String       @id @default(cuid())
  applicationId String       @map("application_id")
  jobId         String       @map("job_id")
  pdfPath       String       @map("pdf_path")
  latexPath     String       @map("latex_path")
  generatedAt   DateTime     @default(now()) @map("generated_at")

  job           Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application   Application  @relation("JobAppResumes", fields: [applicationId], references: [id], onDelete: Cascade)
  applications  Application[] @relation("AppToResume")

  @@index([applicationId])
  @@index([jobId])
}

model Lead {
  id             String    @id @default(cuid())
  companyName    String    @map("company_name")
  recipientEmail String    @map("recipient_email")
  jobDescription String    @map("job_description")
  status         String    @default("READY") // READY, SENDING, SENT, FAILED
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  messages       Message[]

  @@map("leads")
}

model Message {
  id        String    @id @default(cuid())
  leadId    String    @map("lead_id")
  type      String    // INITIAL, FOLLOWUP_1, FOLLOWUP_2, FOLLOWUP_3
  subject   String
  body      String
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Resume {
  id          String   @id @default(cuid())
  title       String
  fileUrl     String?  @map("file_url")
  parsedText  String   @map("parsed_text")
  skills      String[]
  experience  String?  // Rich text/plain text or JSON
  projects    String?  // Rich text/plain text or JSON
  createdAt   DateTime @default(now()) @map("created_at")

  generationJobs GenerationJob[]

  @@map("resumes")
}

model Profile {
  id          String   @id @default(cuid())
  name        String
  role        String
  company     String
  linkedinUrl String?  @map("linkedin_url")
  email       String?
  notes       String?
  source      String   @default("MANUAL")
  tags        String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  generationJobs      GenerationJob[]
  outboundMessages    OutboundMessage[]
  conversationTracker ConversationTracker?

  @@map("profiles")
}

model Template {
  id        String   @id @default(cuid())
  name      String
  type      String   // REFERRAL, NETWORKING, FEEDBACK, FOUNDER
  prompt    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  generationJobs GenerationJob[]

  @@map("templates")
}

model GenerationJob {
  id               String    @id @default(cuid())
  profileId        String    @map("profile_id")
  resumeId         String    @map("resume_id")
  jobId            String?   @map("job_id")
  templateId       String    @map("template_id")
  status           String    @default("PENDING") // PENDING, GENERATING, COMPLETED, FAILED
  generatedSubject String?   @map("generated_subject")
  generatedMessage String?   @map("generated_message")
  error            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resume   Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([resumeId])
  @@index([templateId])
  @@map("generation_jobs")
}

model OutboundMessage {
  id          String    @id @default(cuid())
  profileId   String    @map("profile_id")
  channel     String    @default("EMAIL") // EMAIL, LINKEDIN, etc.
  subject     String
  content     String
  status      String    @default("DRAFT") // DRAFT, APPROVED, REJECTED, EDITED, PENDING, SENDING, SENT, FAILED, REPLIED
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([status])
  @@map("outbound_messages")
}

model ConversationTracker {
  id              String    @id @default(cuid())
  profileId       String    @unique @map("profile_id")
  status          String    @default("ACTIVE")
  lastContactedAt DateTime? @map("last_contacted_at")
  replyReceived   Boolean   @default(false) @map("reply_received")
  positiveResponse Boolean  @default(false) @map("positive_response")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("conversation_trackers")
}

