datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Job {
  id         String    @id @default(cuid())
  source     String    // e.g. "wellfound", "yc", "linkedin"
  externalId String    @map("external_id")
  title      String
  company    String
  location   String
  salary     String?
  applyUrl   String?   @map("apply_url")
  description String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")

  // Tracking fields
  status     String?
  platform   String?
  notes      String?
  appliedAt  DateTime? @map("applied_at")

  // Relations for Auto Apply System
  applications Application[]
  resumes      ResumeVersion[]

  @@unique([source, externalId])
  @@index([source])
  @@index([company])
  @@index([status])
}

model Application {
  id               String         @id @default(cuid())
  jobId            String         @map("job_id")
  userId           String         @map("user_id") @default("default-user")
  status           String         // QUEUED, GENERATING_RESUME, READY_TO_APPLY, APPLYING, APPLIED, FAILED
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  appliedAt        DateTime?      @map("applied_at")
  errorMessage     String?        @map("error_message")
  resumeVersionId  String?        @map("resume_version_id")

  job              Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion    ResumeVersion? @relation("AppToResume", fields: [resumeVersionId], references: [id])
  resumeVersions   ResumeVersion[] @relation("JobAppResumes")

  @@index([jobId])
  @@index([userId])
  @@index([status])
}

model ResumeVersion {
  id            String       @id @default(cuid())
  applicationId String       @map("application_id")
  jobId         String       @map("job_id")
  pdfPath       String       @map("pdf_path")
  latexPath     String       @map("latex_path")
  generatedAt   DateTime     @default(now()) @map("generated_at")

  job           Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application   Application  @relation("JobAppResumes", fields: [applicationId], references: [id], onDelete: Cascade)
  applications  Application[] @relation("AppToResume")

  @@index([applicationId])
  @@index([jobId])
}

model Lead {
  id             String    @id @default(cuid())
  companyName    String    @map("company_name")
  recipientEmail String    @map("recipient_email")
  jobDescription String    @map("job_description")
  status         String    @default("READY") // READY, SENDING, SENT, FAILED
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  messages       Message[]

  @@map("leads")
}

model Message {
  id        String    @id @default(cuid())
  leadId    String    @map("lead_id")
  type      String    // INITIAL, FOLLOWUP_1, FOLLOWUP_2, FOLLOWUP_3
  subject   String
  body      String
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("messages")
}

